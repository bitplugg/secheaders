{
  "openapi": "3.0.3",
  "info": {
    "title": "SecHeaders API",
    "description": "REST API для анализа безопасности веб-сайтов. Все эндпоинты работают на Edge Runtime.",
    "version": "1.0.0",
    "contact": { "url": "https://github.com/bitplugg/secheaders" }
  },
  "servers": [
    { "url": "https://zxc-r1spclf9a-bitplugg.vercel.app", "description": "Продакшен" },
    { "url": "http://localhost:3000", "description": "Локальная разработка" }
  ],
  "paths": {
    "/api/scan": {
      "get": {
        "summary": "Сканирование HTTP-заголовков безопасности",
        "parameters": [
          { "name": "url", "in": "query", "required": true, "schema": { "type": "string", "format": "uri" }, "example": "https://google.com" }
        ],
        "responses": {
          "200": {
            "description": "Результат сканирования",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ScanResponse" } } }
          }
        }
      }
    },
    "/api/batch": {
      "get": {
        "summary": "Массовое сканирование (до 10 URL)",
        "parameters": [
          { "name": "urls", "in": "query", "required": true, "schema": { "type": "string" }, "example": "https://google.com,https://github.com" }
        ],
        "responses": { "200": { "description": "Результаты" } }
      }
    },
    "/api/compare": {
      "get": {
        "summary": "Сравнение двух сайтов",
        "parameters": [
          { "name": "a", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "b", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Сравнение" } }
      }
    },
    "/api/dns": {
      "get": {
        "summary": "DNS-запросы через Cloudflare DoH",
        "parameters": [
          { "name": "domain", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "types", "in": "query", "required": false, "schema": { "type": "string" }, "description": "Через запятую: A,AAAA,MX,TXT,NS,CNAME,SOA,CAA,SRV" }
        ],
        "responses": { "200": { "description": "DNS-записи" } }
      }
    },
    "/api/ssl": { "get": { "summary": "SSL / HTTPS / HSTS проверка", "parameters": [{ "name": "url", "in": "query", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "SSL-информация" } } } },
    "/api/tls": { "get": { "summary": "TLS / HTTP/2 / HTTP/3", "parameters": [{ "name": "url", "in": "query", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "TLS-информация" } } } },
    "/api/cors": { "get": { "summary": "CORS-заголовки", "parameters": [{ "name": "url", "in": "query", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "CORS-результат" } } } },
    "/api/cookies": { "get": { "summary": "Cookie-безопасность", "parameters": [{ "name": "url", "in": "query", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "Cookie-анализ" } } } },
    "/api/mixed": { "get": { "summary": "Mixed Content", "parameters": [{ "name": "url", "in": "query", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "Mixed-контент" } } } },
    "/api/redirects": { "get": { "summary": "Цепочка редиректов", "parameters": [{ "name": "url", "in": "query", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "Редиректы" } } } },
    "/api/gzip": { "get": { "summary": "Проверка сжатия GZIP/Brotli", "parameters": [{ "name": "url", "in": "query", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "Сжатие" } } } },
    "/api/csp-dump": { "get": { "summary": "CSP-анализ (директивы)", "parameters": [{ "name": "url", "in": "query", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "CSP-директивы" } } } },
    "/api/csp-eval": { "get": { "summary": "CSP-оценка безопасности", "parameters": [{ "name": "url", "in": "query", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "CSP-оценка" } } } },
    "/api/pwa": { "get": { "summary": "PWA-валидация", "parameters": [{ "name": "url", "in": "query", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "PWA-результат" } } } },
    "/api/subdomains": { "get": { "summary": "Поиск поддоменов через crt.sh", "parameters": [{ "name": "domain", "in": "query", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "Поддомены" } } } },
    "/api/email-security": { "get": { "summary": "SPF/DKIM/DMARC", "parameters": [{ "name": "domain", "in": "query", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "Email-безопасность" } } } },
    "/api/server": { "get": { "summary": "Информация о сервере", "parameters": [{ "name": "url", "in": "query", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "Сервер" } } } },
    "/api/page-info": { "get": { "summary": "Мета-информация страницы", "parameters": [{ "name": "url", "in": "query", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "Информация" } } } },
    "/api/cdn": { "get": { "summary": "Определение CDN", "parameters": [{ "name": "url", "in": "query", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "CDN" } } } },
    "/api/schema": { "get": { "summary": "Schema.org / JSON-LD", "parameters": [{ "name": "url", "in": "query", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "Schema" } } } },
    "/api/whois": { "get": { "summary": "WHOIS-данные через RDAP", "parameters": [{ "name": "domain", "in": "query", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "WHOIS" } } } },
    "/api/preview": { "get": { "summary": "Open Graph / Link Preview", "parameters": [{ "name": "url", "in": "query", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "Preview" } } } },
    "/api/sri": { "get": { "summary": "SRI-валидация скриптов", "parameters": [{ "name": "url", "in": "query", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "SRI" } } } },
    "/api/sri-gen": { "get": { "summary": "Генерация SRI-хеша", "parameters": [{ "name": "url", "in": "query", "required": true, "schema": { "type": "string" } }, { "name": "algorithm", "in": "query", "schema": { "type": "string", "enum": ["sha256","sha384","sha512"], "default": "sha384" } }], "responses": { "200": { "description": "SRI-хеш" } } } },
    "/api/methods": { "get": { "summary": "HTTP-методы", "parameters": [{ "name": "url", "in": "query", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "Методы" } } } },
    "/api/contrast": { "get": { "summary": "WCAG-контраст цветов", "parameters": [{ "name": "foreground", "in": "query", "schema": { "type": "string" } }, { "name": "background", "in": "query", "schema": { "type": "string" } }, { "name": "fontSize", "in": "query", "schema": { "type": "number" } }], "responses": { "200": { "description": "Контраст" } } } },
    "/api/encode": { "get": { "summary": "Base64/URL Encode/Decode", "parameters": [{ "name": "input", "in": "query", "required": true, "schema": { "type": "string" } }, { "name": "action", "in": "query", "schema": { "type": "string", "enum": ["encode","decode"] } }, { "name": "type", "in": "query", "schema": { "type": "string", "enum": ["base64","url"] } }], "responses": { "200": { "description": "Результат" } } } },
    "/api/hash": { "get": { "summary": "Хеширование SHA", "parameters": [{ "name": "input", "in": "query", "required": true, "schema": { "type": "string" } }, { "name": "algorithm", "in": "query", "schema": { "type": "string", "enum": ["sha1","sha256","sha384","sha512"], "default": "sha256" } }], "responses": { "200": { "description": "Хеш" } } } },
    "/api/jwt": { "get": { "summary": "Декодирование JWT", "parameters": [{ "name": "token", "in": "query", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "JWT" } } } },
    "/api/pretty": { "get": { "summary": "Pretty Print JSON/XML", "parameters": [{ "name": "input", "in": "query", "required": true, "schema": { "type": "string" } }, { "name": "type", "in": "query", "schema": { "type": "string", "enum": ["auto","json","xml"] } }], "responses": { "200": { "description": "Форматирование" } } } },
    "/api/ping": { "get": { "summary": "Проверка доступности", "parameters": [{ "name": "url", "in": "query", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "Ping" } } } },
    "/api/broken-links": { "get": { "summary": "Поиск битых ссылок", "parameters": [{ "name": "url", "in": "query", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "Ссылки" } } } },
    "/api/clone": { "get": { "summary": "Поиск клонов сайта", "parameters": [{ "name": "url", "in": "query", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "Клоны" } } } },
    "/api/deps": { "get": { "summary": "Определение JS-библиотек и CMS", "parameters": [{ "name": "url", "in": "query", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "Зависимости" } } } },
    "/api/diff": { "get": { "summary": "HTTP-diff двух URL", "parameters": [{ "name": "a", "in": "query", "required": true, "schema": { "type": "string" } }, { "name": "b", "in": "query", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "Diff" } } } },
    "/api/favicon": { "get": { "summary": "Поиск favicon", "parameters": [{ "name": "url", "in": "query", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "Favicon" } } } },
    "/api/feed": { "get": { "summary": "Поиск RSS/Atom", "parameters": [{ "name": "url", "in": "query", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "Feeds" } } } },
    "/api/meta": { "get": { "summary": "SEO-метатеги", "parameters": [{ "name": "url", "in": "query", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "Мета" } } } },
    "/api/sitemap": { "get": { "summary": "Анализ sitemap.xml", "parameters": [{ "name": "url", "in": "query", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "Sitemap" } } } },
    "/api/ssrf": { "get": { "summary": "SSRF-проверка", "parameters": [{ "name": "url", "in": "query", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "SSRF" } } } },
    "/api/validator": { "get": { "summary": "HTML-валидация через W3C", "parameters": [{ "name": "url", "in": "query", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "Валидация" } } } },
    "/api/wayback": { "get": { "summary": "Archive.org история", "parameters": [{ "name": "url", "in": "query", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "Wayback" } } } },
    "/api/well-known": { "get": { "summary": ".well-known проверка", "parameters": [{ "name": "url", "in": "query", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "Well-known" } } } },
    "/api/wp": { "get": { "summary": "WordPress-сканер", "parameters": [{ "name": "url", "in": "query", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "WP" } } } }
  },
  "components": {
    "schemas": {
      "HeaderCheck": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "displayName": { "type": "string" },
          "description": { "type": "string" },
          "value": { "type": "string", "nullable": true },
          "score": { "type": "integer" },
          "maxScore": { "type": "integer" },
          "details": { "type": "string" }
        }
      },
      "ScanResult": {
        "type": "object",
        "properties": {
          "url": { "type": "string" },
          "status": { "type": "integer" },
          "headers": { "type": "array", "items": { "$ref": "#/components/schemas/HeaderCheck" } },
          "overallScore": { "type": "integer" },
          "maxScore": { "type": "integer" },
          "grade": { "type": "string", "enum": ["A","B","C","D","E","F"] },
          "timestamp": { "type": "integer" }
        }
      },
      "ScanResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "data": { "$ref": "#/components/schemas/ScanResult" },
          "error": { "type": "string" }
        }
      }
    }
  }
}
